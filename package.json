{
  "name": "web_app",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev --host 0.0.0.0 --port 3000",
    "build": "nuxt build",
    "start": "node .output/server/index.mjs",
    "generate:feature": "node ./scripts/generate-web-slice.mjs --app-dir . --type feature",
    "generate:page": "node ./scripts/generate-web-slice.mjs --app-dir . --type page",
    "generate:widget": "node ./scripts/generate-web-slice.mjs --app-dir . --type widget",
    "test": "vitest run",
    "lint:fast": "oxlint src tests",
    "lint": "npm run lint:fast && eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "dependencies": {
    "nuxt": "^3.12.4"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.11.0",
    "@typescript-eslint/parser": "^8.11.0",
    "@vitejs/plugin-vue": "^5.1.2",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.29.0",
    "happy-dom": "^15.11.7",
    "oxlint": "^1.62.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "vue-eslint-parser": "^9.4.3",
    "vitest": "^2.0.5"
  }
}
